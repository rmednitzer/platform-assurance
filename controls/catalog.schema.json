{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "catalog_status", "catalog_owner", "controls"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "catalog_status": {"type": "string"},
    "catalog_owner": {"type": "string"},
    "catalog_purpose": {"type": "string"},
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "control_id", "title", "status", "artifact_type", "boundary", "objective",
          "required_capability", "approved_patterns", "owners", "verification_command",
          "evidence_schema", "exception_process", "applicability"
        ],
        "properties": {
          "control_id": {"type": "string", "pattern": "^CTL-[0-9]{4}$"},
          "title": {"type": "string", "minLength": 3},
          "status": {"type": "string"},
          "artifact_type": {"type": "string", "enum": ["normative", "approved-pattern", "illustrative", "deprecated", "environment-specific"]},
          "boundary": {"type": "string"},
          "objective": {"type": "string"},
          "required_capability": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "approved_patterns": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "owners": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "verification_command": {"type": "string", "minLength": 3},
          "evidence_schema": {
            "type": "object",
            "required": ["artifact_type", "required_files", "retention_tier"],
            "properties": {
              "artifact_type": {"type": "string"},
              "required_files": {"type": "array", "minItems": 1, "items": {"type": "string"}},
              "retention_tier": {"type": "string"}
            },
            "additionalProperties": true
          },
          "exception_process": {"type": "string", "minLength": 3},
          "applicability": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["framework", "regulatory_ref", "roles", "applicable_from"],
              "properties": {
                "framework": {"type": "string"},
                "regulatory_ref": {"type": "string"},
                "roles": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                "applicable_from": {"type": "string", "format": "date"},
                "applicable_until": {"type": "string", "format": "date"},
                "condition": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
